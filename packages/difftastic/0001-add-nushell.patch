From 105727febc375be6b34af53375de9e31dda1da62 Mon Sep 17 00:00:00 2001
From: Juhan280 <azurarobo280@gmail.com>
Date: Mon, 25 May 2026 01:10:35 +0600
Subject: [PATCH] add nushell

---
 Cargo.toml                      |  1 +
 src/parse/guess_language.rs     |  4 ++++
 src/parse/tree_sitter_parser.rs | 16 ++++++++++++++++
 3 files changed, 21 insertions(+)

diff --git a/Cargo.toml b/Cargo.toml
index 2af4abd..0bda88b 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -105,6 +105,7 @@ tree-sitter-lua = "0.5"
 tree-sitter-make = "1.1.1"
 tree-sitter-newick = "1.1.0"
 tree-sitter-nix = "0.3.0"
+tree-sitter-nu = { git = "https://github.com/nushell/tree-sitter-nu" }
 tree-sitter-objc = "3.0.2"
 tree-sitter-ocaml = "0.24.0"
 tree-sitter-pascal = "0.10.0"
diff --git a/src/parse/guess_language.rs b/src/parse/guess_language.rs
index 1117125..ba72852 100644
--- a/src/parse/guess_language.rs
+++ b/src/parse/guess_language.rs
@@ -57,6 +57,7 @@ pub(crate) enum Language {
     Make,
     Newick,
     Nix,
+    Nushell,
     ObjC,
     OCaml,
     OCamlInterface,
@@ -159,6 +160,7 @@ pub(crate) fn language_name(language: Language) -> &'static str {
         Make => "Make",
         Newick => "Newick",
         Nix => "Nix",
+        Nushell => "Nushell",
         ObjC => "Objective-C",
         OCaml => "OCaml",
         OCamlInterface => "OCaml Interface",
@@ -352,6 +354,7 @@ pub(crate) fn language_globs(language: Language) -> Vec<glob::Pattern> {
         ],
         Newick => &["*.nhx", "*.nwk", "*.nh"],
         Nix => &["*.nix"],
+        Nushell => &["*.nu", "*.nuon"],
         ObjC => &["*.m"],
         OCaml => &["*.ml"],
         OCamlInterface => &["*.mli"],
@@ -601,6 +604,7 @@ fn from_shebang(src: &str) -> Option<Language> {
                     "runghc" | "runhaskell" | "runhugs" => return Some(Haskell),
                     "chakra" | "d8" | "gjs" | "js" | "node" | "nodejs" | "qjs" | "rhino" | "v8"
                     | "v8-shell" => return Some(JavaScript),
+                    "nu" => return Some(Nushell),
                     "ocaml" | "ocamlrun" | "ocamlscript" => return Some(OCaml),
                     "perl" => return Some(Perl),
                     "python" | "python2" | "python3" => return Some(Python),
diff --git a/src/parse/tree_sitter_parser.rs b/src/parse/tree_sitter_parser.rs
index 3c33adb..8a9afbe 100644
--- a/src/parse/tree_sitter_parser.rs
+++ b/src/parse/tree_sitter_parser.rs
@@ -797,6 +797,22 @@ pub(crate) fn from_language(language: guess::Language) -> TreeSitterConfig {
                 sub_languages: vec![],
             }
         }
+        Nushell => {
+            let language_fn = tree_sitter_nu::LANGUAGE;
+            let language = tree_sitter::Language::new(language_fn);
+
+            TreeSitterConfig {
+                language: language.clone(),
+                atom_nodes: ["string_content"].into_iter().collect(),
+                delimiter_tokens: vec![("{", "}"), ("{", "}"), ("[", "]")]
+                    .into_iter()
+                    .collect(),
+                ignore_trailing_tokens: vec![],
+                highlight_query: ts::Query::new(&language, tree_sitter_nu::HIGHLIGHTS_QUERY)
+                    .unwrap(),
+                sub_languages: vec![],
+            }
+        }
         ObjC => {
             let language_fn = tree_sitter_objc::LANGUAGE;
             let language = tree_sitter::Language::new(language_fn);
-- 
2.43.0

